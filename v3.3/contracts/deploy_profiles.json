{
  "schema_version": 2,
  "contract_name": "Savage22 maintained deployment profiles",
  "private_shop_controls_path": "contracts/private_shop_controls.json",
  "runtime_home_default_windows": "C:\\Users\\C\\Documents\\Savage22 Runtime",
  "runtime_home_default_posix": "/workspace/runtime",
  "timeframes": {
    "1w": {
      "warm_start_parent": null,
      "execution_mode": "cpu_first_trimmed",
      "execution_policy": {
        "failure_mode": "fail_fast",
        "phase_order": "strict",
        "post_train_fanout": false
      },
      "machine_policy": {
        "hard_floor": {
          "cpu_cores": 16,
          "ram_gb": 64,
          "gpu_count": 1
        },
        "preferred_profile": {
          "cpu_cores": 32,
          "ram_gb": 128,
          "gpu_count": 1,
          "gpu_role": "optional",
          "notes": "Maintained weekly path is base-features-only and CPU-first."
        }
      },
      "env_defaults": {
        "ALLOW_CPU": "1",
        "OPTUNA_MULTI_GPU_SEARCH": "0"
      },
      "download_policy": {
        "shared_seed_source": "gcs-manifest",
        "restore_parent_artifacts": false,
        "download_prior_checkpoints": false
      },
      "resume_policy": {
        "prefer_resume_boundaries": [
          "features_validated",
          "optuna_validated",
          "train_validated",
          "optimizer_validated"
        ],
        "allow_cross_resume": false
      },
      "same_machine_required": false,
      "forbidden_behaviors": [
        "force_cross_generation",
        "artifact_root_equals_code_root",
        "accept_shared_root_run_artifacts"
      ],
      "post_train_required": [
        "step6_optimizer"
      ]
    },
    "1d": {
      "warm_start_parent": "1w",
      "execution_mode": "cpu_first",
      "execution_policy": {
        "failure_mode": "fail_fast",
        "phase_order": "strict",
