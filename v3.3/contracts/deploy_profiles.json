      "download_policy": {
        "shared_seed_source": "gcs-manifest",
        "restore_parent_artifacts": true,
        "download_prior_checkpoints": true
      },
      "resume_policy": {
        "prefer_resume_boundaries": [
          "features_validated",
          "crosses_validated",
          "optuna_validated",
          "train_validated",
          "optimizer_validated"
        ],
        "allow_cross_resume": true
