      "same_machine_required": false,
      "forbidden_behaviors": [
        "skip_cross_generation",
        "force_cpu_only",
        "artifact_root_equals_code_root",
        "accept_shared_root_run_artifacts"
      ],
      "post_train_required": [
        "step6_optimizer",
        "step7_meta",
        "step8_lstm",
        "step9_pbo",
        "step10_audit"
