    "15m": {
      "warm_start_parent": "1h",
      "execution_mode": "gpu_required_same_machine",
      "execution_policy": {
        "failure_mode": "fail_fast",
        "phase_order": "strict",
        "post_train_fanout": true
      },
      "machine_policy": {
        "hard_floor": {
          "cpu_cores": 96,
